generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id        String   @id @default(cuid())
  filename  String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("resumes")
}

model Application {
  id           String   @id @default(cuid())
  url          String
  company      String
  role         String
  location     String
  salaryRange  String?  @map("salary_range")
  summary      String
  requirements String
  potentialImprovements String @map("potential_improvements")
  fitScore     Int      @map("fit_score")
  fitReasoning String   @map("fit_reasoning")
  status       String   @default("SAVED")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("applications")
}
