generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String             @unique
  emailVerified    DateTime?          @map("email_verified")
  image            String?
  password         String?
  accounts         Account[]
  sessions         Session[]
  resumes          Resume[]
  applications     Application[]
  discoveredJobs   DiscoveredJob[]
  jobSearchProfile JobSearchProfile?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Resume {
  id        String   @id @default(cuid())
  filename  String
  content   String
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("resumes")
}

model Application {
  id                    String   @id @default(cuid())
  url                   String
  company               String
  role                  String
  location              String
  salaryRange           String?  @map("salary_range")
  summary               String
  requirements          String
  potentialImprovements String   @map("potential_improvements")
  fitScore              Int      @map("fit_score")
  fitReasoning          String   @map("fit_reasoning")
  status                String   @default("SAVED")
  notes                 String?
  userId                String   @map("user_id")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([userId, url])
  @@map("applications")
}

model DiscoveredJob {
  id               String    @id @default(cuid())
  title            String
  company          String
  location         String
  url              String
  salaryRange      String?   @map("salary_range")
  description      String
  source           String
  atsJobId         String    @map("ats_job_id")
  postedAt         DateTime? @map("posted_at")
  seniorityLevel   String?   @map("seniority_level")
  remoteStatus     String?   @map("remote_status")
  fitScore         Int       @map("fit_score")
  matchExplanation String    @map("match_explanation")
  companyFunding   String?   @map("company_funding")
  dismissed        Boolean   @default(false)
  tracked          Boolean   @default(false)
  discoveredAt     DateTime  @default(now()) @map("discovered_at")
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, atsJobId])
  @@map("discovered_jobs")
}

model JobSearchProfile {
  id                  String   @id @default(cuid())
  targetCompanies     String   @map("target_companies")
  targetRoles         String   @map("target_roles")
  skills              String
  seniorityLevel      String   @map("seniority_level")
  yearsOfExperience   Int?     @map("years_of_experience")
  locationPreferences String   @map("location_preferences")
  industryPreferences String?  @map("industry_preferences")
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("job_search_profiles")
}
